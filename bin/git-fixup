#!/bin/bash

first_arg=$1

usage() {
  echo "❗️ Usage: git fixup <relative-commit-number>"
  echo ""
  echo "Automates the process of adding staged changes to a previous commit."
  echo "You can use \`git l\` to get the relative commit number."
  echo ""
  echo "    ❯ git l"
  echo "    0 * d1d96ed  5 minutes ago   noah      (HEAD -> master) Fixup + Log: use 0-index relative number"
  echo "    1 * 088050b  18 hours ago    noah      (origin/master, origin/HEAD) homebrew-git-stack 2.9.9"
  echo "    2 * c7e4065  18 hours ago    noah      (tag: 2.9.9) 2.9.9"
  echo ""
  echo "You can also use \`git log\` to get the relative commit number."
  echo ""
  echo "    ❯ git log --pretty=oneline -n10 | nl -v0"
  echo "    0	e329794 enable drop_error_subtask test param"
  echo "    1	57f43b5 test drop_error_subtask baseline"
  echo "    2	838e878 ErrorSubtask test baseline"
  echo ""
  echo "To target \`838e878\` above, you would call \`git fixup 2\`"
}

if [[ "$first_arg" =~ "help" ]]; then
  usage
  exit 0
fi

if git diff --text --cached --quiet; then
  usage
  echo
  echo "🚨 Stage changes before calling fixup"
  exit 2
fi

relative_number=${first_arg:-0}

if [ -z "$relative_number" ]; then
  usage
  exit 1
fi

# get the commit SHA of the target commit
commit_sha=$(git rev-parse HEAD~"$relative_number")

echo "🛠️ fixup [$commit_sha] ($relative_number)"
git commit --fixup "$commit_sha"

# check if stash required
if git diff-index --text --quiet HEAD --; then
  save_stash=false
else
  save_stash=true
  git stash -q
  echo "📦 Changes saved to stash"
fi

# rebase target needs to account for new commit created above
rebase_target=$((relative_number + 2))
git rebase -i --autosquash HEAD~"$rebase_target"

if [ "$save_stash" = true ]; then
  git stash pop -q
  echo "✅ Changes restored from stash"
fi
